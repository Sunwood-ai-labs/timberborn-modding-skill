          <mxGeometry x="0" y="0" width="1800" height="1200" as="geometry"/>
        </mxCell>

        <mxCell id="title" value="新規建物アセットの作成フロー" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=34;fontStyle=1;fontFamily=Noto Sans JP;fontColor=#f3fff7;" vertex="1" parent="1">
          <mxGeometry x="52" y="38" width="980" height="42" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Timberborn の新しい配置物を作るときの標準ルート。Route A/B は「新規建物アセット」トラックの中で分岐する。" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=16;fontFamily=Noto Sans JP;fontColor=#c4d2cb;" vertex="1" parent="1">
          <mxGeometry x="54" y="86" width="1240" height="28" as="geometry"/>
        </mxCell>

        <mxCell id="scope" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;SCOPE&lt;/font&gt;&lt;br&gt;&lt;b&gt;この図の対象&lt;/b&gt;&lt;br&gt;新規建物アセット向け。&lt;br&gt;既存値だけの変更なら&lt;br&gt;&lt;b&gt;Empty + JSON content mod&lt;/b&gt; が先。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#3f4942;strokeWidth=1.5;fontSize=18;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="56" y="160" width="290" height="176" as="geometry"/>
        </mxCell>

        <mxCell id="inputs" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;INPUTS&lt;/font&gt;&lt;br&gt;&lt;b&gt;先に決めること&lt;/b&gt;&lt;br&gt;・建物名 / faction / category&lt;br&gt;・footprint と完成後の役割&lt;br&gt;・元の texture を保つか&lt;br&gt;・Built-in material で寄せるか" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#3f4942;strokeWidth=1.5;fontSize=18;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="56" y="370" width="290" height="210" as="geometry"/>
        </mxCell>

        <mxCell id="guardrails" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;GUARDRAILS&lt;/font&gt;&lt;br&gt;&lt;b&gt;失敗しにくい前提&lt;/b&gt;&lt;br&gt;・土台は &lt;b&gt;Example building&lt;/b&gt;&lt;br&gt;・最初は完成モデル 1 個だけ&lt;br&gt;・Route B では .mat と .png の basename を分ける&lt;br&gt;・material / bundle 更新後は完全再起動&lt;br&gt;・値が Blueprint に出ないなら C# / BepInEx を検討" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#3f4942;strokeWidth=1.5;fontSize=17;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="56" y="620" width="290" height="300" as="geometry"/>
        </mxCell>

        <mxCell id="start" value="&lt;font style=&quot;font-size:11px;color:#dffbea;letter-spacing:1px;&quot;&gt;START&lt;/font&gt;&lt;br&gt;&lt;b&gt;新規建物アセットを作りたい&lt;/b&gt;&lt;br&gt;配置可能な建物として追加する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2f855a;gradientColor=#83d8a6;gradientDirection=north;strokeColor=#83d8a6;strokeWidth=1.5;fontSize=18;fontFamily=Noto Sans JP;fontColor=#0f1712;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="410" y="170" width="240" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="step1" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;STEP 1&lt;/font&gt;&lt;br&gt;&lt;b&gt;Example building で土台を作る&lt;/b&gt;&lt;br&gt;Blueprint / icon / localization / 登録例を確保" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#3f4942;strokeWidth=1.5;fontSize=17;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="700" y="166" width="250" height="142" as="geometry"/>
        </mxCell>

        <mxCell id="step2" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;STEP 2&lt;/font&gt;&lt;br&gt;&lt;b&gt;名前と仕様を固定する&lt;/b&gt;&lt;br&gt;建物 ID / faction / footprint / ToolGroup / cost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#3f4942;strokeWidth=1.5;fontSize=17;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="1010" y="166" width="260" height="142" as="geometry"/>
        </mxCell>

        <mxCell id="step3" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;STEP 3&lt;/font&gt;&lt;br&gt;&lt;b&gt;Blender でモデルを整える&lt;/b&gt;&lt;br&gt;原点 / 向き / スケール / UV / Collection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#3f4942;strokeWidth=1.5;fontSize=17;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="1320" y="164" width="280" height="146" as="geometry"/>
        </mxCell>

        <mxCell id="decision1" value="&lt;b&gt;元の texture を&lt;br&gt;保ちたい？&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#333537;strokeColor=#83d8a6;strokeWidth=2;fontSize=18;fontStyle=1;fontFamily=Noto Sans JP;fontColor=#f3fff7;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1390" y="375" width="170" height="140" as="geometry"/>
