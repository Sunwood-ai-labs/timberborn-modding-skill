        <mxCell id="routeA" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;ROUTE A&lt;/font&gt;&lt;br&gt;&lt;b&gt;Built-in material で進める&lt;/b&gt;&lt;br&gt;・Blender CLI で .timbermesh export&lt;br&gt;・Unity は使わない&lt;br&gt;・Timberborn 風に寄せる" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#83d8a6;strokeWidth=2;fontSize=17;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
