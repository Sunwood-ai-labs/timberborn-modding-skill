  <diagram id="new-building-asset-flow" name="New Building Asset Flow">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1260" math="0" shadow="0" background="none" defaultFontFamily="Noto Sans JP">
