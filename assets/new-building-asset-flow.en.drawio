        <mxCell id="scope" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;SCOPE&lt;/font&gt;&lt;br&gt;&lt;b&gt;What this covers&lt;/b&gt;&lt;br&gt;New building assets.&lt;br&gt;For value-only tweaks,&lt;br&gt;&lt;b&gt;use Empty + JSON content mod&lt;/b&gt;." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#3f4942;strokeWidth=1.5;fontSize=17;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
