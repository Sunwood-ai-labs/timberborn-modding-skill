        <mxCell id="inputs" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;INPUTS&lt;/font&gt;&lt;br&gt;&lt;b&gt;Decide first&lt;/b&gt;&lt;br&gt;• name / faction / category&lt;br&gt;• footprint and gameplay role&lt;br&gt;• keep the original texture?&lt;br&gt;• are built-in materials enough?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#3f4942;strokeWidth=1.5;fontSize=17;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="56" y="370" width="290" height="238" as="geometry"/>
        </mxCell>

        <mxCell id="guardrails" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;GUARDRAILS&lt;/font&gt;&lt;br&gt;&lt;b&gt;Low-risk defaults&lt;/b&gt;&lt;br&gt;• Start from &lt;b&gt;Example building&lt;/b&gt;&lt;br&gt;• Begin with one finished model&lt;br&gt;• In Route B, keep .mat and .png basenames different&lt;br&gt;• Fully restart after material or bundle changes&lt;br&gt;• If Blueprint hides the value, consider C# or BepInEx" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#3f4942;strokeWidth=1.5;fontSize=17;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
