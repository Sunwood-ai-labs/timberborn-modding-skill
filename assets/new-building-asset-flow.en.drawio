        <mxCell id="title" value="New Building Asset Creation Flow" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=34;fontStyle=1;fontFamily=Noto Sans JP;fontColor=#f3fff7;" vertex="1" parent="1">
