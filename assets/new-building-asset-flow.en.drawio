        <mxCell id="routeB" value="&lt;font style=&quot;font-size:11px;color:#c7f3d7;letter-spacing:1px;&quot;&gt;ROUTE B&lt;/font&gt;&lt;br&gt;&lt;b&gt;Keep the texture&lt;/b&gt;&lt;br&gt;• export .timbermesh + texture&lt;br&gt;• create a Material in Unity&lt;br&gt;• add AssetBundle and MaterialCollection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2f855a;strokeColor=#83d8a6;strokeWidth=2;fontSize=17;fontFamily=Noto Sans JP;fontColor=#f4fff8;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
