        <mxCell id="subtitle" value="Standard route for a new Timberborn placeable. Route A and Route B branch only inside the new building asset track." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=16;fontFamily=Noto Sans JP;fontColor=#c4d2cb;" vertex="1" parent="1">
