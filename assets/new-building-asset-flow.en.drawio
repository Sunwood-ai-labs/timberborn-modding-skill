        <mxCell id="start" value="&lt;font style=&quot;font-size:11px;color:#dffbea;letter-spacing:1px;&quot;&gt;START&lt;/font&gt;&lt;br&gt;&lt;b&gt;I want a new building asset&lt;/b&gt;&lt;br&gt;Add a new placeable building" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2f855a;gradientColor=#83d8a6;gradientDirection=north;strokeColor=#83d8a6;strokeWidth=1.5;fontSize=18;fontFamily=Noto Sans JP;fontColor=#0f1712;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="410" y="170" width="240" height="150" as="geometry"/>
