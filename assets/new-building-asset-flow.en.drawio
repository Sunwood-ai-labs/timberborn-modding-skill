        <mxCell id="step3" value="&lt;font style=&quot;font-size:11px;color:#83d8a6;letter-spacing:1px;&quot;&gt;STEP 3&lt;/font&gt;&lt;br&gt;&lt;b&gt;Prepare the model in Blender&lt;/b&gt;&lt;br&gt;origin / facing / scale / UV / collection" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1c1e;strokeColor=#3f4942;strokeWidth=1.5;fontSize=17;fontFamily=Noto Sans JP;fontColor=#edf7f0;align=left;verticalAlign=middle;spacingLeft=18;spacingRight=16;spacingTop=16;spacingBottom=16;arcSize=18;" vertex="1" parent="1">
          <mxGeometry x="1320" y="164" width="280" height="146" as="geometry"/>
        </mxCell>

        <mxCell id="decision1" value="&lt;b&gt;Keep the original&lt;br&gt;texture?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#333537;strokeColor=#83d8a6;strokeWidth=2;fontSize=18;fontStyle=1;fontFamily=Noto Sans JP;fontColor=#f3fff7;align=center;verticalAlign=middle;" vertex="1" parent="1">
